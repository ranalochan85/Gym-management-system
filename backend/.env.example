# Database Configuration
DATABASE_URL=postgresql://gym_user:gym_password@localhost:5432/gym_management
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_key_min_32_characters_required_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Application
APP_NAME=Gym Management System
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
DEBUG_MODE=true

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080

# Redis
REDIS_URL=redis://localhost:6379/0

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@gymsystem.local
SMTP_FROM_NAME=Gym Management System

# Payment Gateway
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_STORAGE_BUCKET_NAME=gym-management-bucket
AWS_S3_REGION_NAME=us-east-1

# Security
SECURE_HEADERS=true
CSRF_PROTECTION=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
